{
  "branches": ["master"],
  "tagFormat": "v${version}-telegram-bot",
  "plugins": [
    ["./.github/scripts/semantic-release-track.cjs", { "track": "telegram-bot" }],
    "@semantic-release/github",
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.telegram-bot.md"],
        "message": "chore(release): telegram-bot ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
