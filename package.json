    "release:android": "semantic-release --extends ./.releaserc.android.json",
    "release:telegram-bot": "semantic-release --extends ./.releaserc.telegram-bot.json",
    "release:dry-run:web": "semantic-release --dry-run --extends ./.releaserc.web.json",
    "release:dry-run:android": "semantic-release --dry-run --extends ./.releaserc.android.json",
    "release:dry-run:telegram-bot": "semantic-release --dry-run --extends ./.releaserc.telegram-bot.json",
    "release:preview": "node .github/scripts/semantic-release-track.cjs preview",
    "changelog:validate": "node .github/scripts/semantic-release-track.cjs validate"
  },
  "repository": {
